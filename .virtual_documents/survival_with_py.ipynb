def categorical_grouped_chart(
    graph: Graph, 
    x: str, 
    hue: str, 
    colors: List[str], 
    target_colors: List[str],
    title: str,
    subtitle: str
    ):

    x_bar = graph.bar_chart(x, color=colors)
    x_donut = graph.donut_chart(x)
    x_vs_hue = graph.col_bar_char(hue, group_by=x, color=target_colors)

    return (
        ((x_bar | x_donut) & x_vs_hue)
        .resolve_scale(color='independent')
        .configure_view(stroke=None)
        .properties(title=alt.Title(title, subtitle=subtitle, fontSize=15, dx=10, dy=-10))
        .display(theme="dark")
    )





