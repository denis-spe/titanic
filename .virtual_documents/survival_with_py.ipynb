class Graph:
    def __init__(
        self, data: pd.DataFrame, map_values: Optional[Dict[str, Dict[Any, Any]]] = None
    ) -> None:
        data = data.copy()

        if map_values:
            for key, value in map_values.items():
                data[key] = data[key].map(lambda col: value[col])

        self.__data = data

    def setting_colors(
        self, x: str, color: List[str] | str
    ) -> Tuple[pd.DataFrame, alt.Color]:

        # Color map.
        if isinstance(color, list):
            alt_color = (
                alt.Color(x).scale(range=color, reverse=True).legend(orient="right")
            )
        else:
            alt_color = (
                alt.Color(x).scale(scheme=color, reverse=True).legend(orient="right")
            )
        return alt_color

    def normalized_bar(self, x, y, hue, color, strategy = 'mean'):
        data = self.__data.copy()
        
        d = data.groupby([y, hue])[x].agg(strategy).reset_index()
    
        alt_color = self.setting_colors(hue, color=color)
        
        bars = alt.Chart(d).mark_bar().encode(
            x=alt.X(f'{strategy}({x}):Q').stack("normalize"),
            y=alt.Y(f'{y}:N'),
            color=alt_color
        )
        
        text = alt.Chart(d).mark_text(dx=-15, dy=3, color='white').encode(
            x=alt.X(f'{strategy}({x}):Q').stack("normalize"),
            y=alt.Y(f'{y}:N'),
            detail=f'{hue}:N',
            text=alt.Text(f'{strategy}({x}):Q', format='.1f')
        )
        
        return bars + text
    def col_bar_char(
        self,
        x_column: str,
        group_by: str,
        color: List | str = "paired",
        width: int = 200,
        height: int = 200,
        title: Optional[str] = None,
        subtitle: Optional[str] = None,
        x_title: str | None = None,
        y_title: str | None = None,
    ):
        alt_color = self.setting_colors(x_column, color=color)

        data = self.__data

        x_title = x_title.title() if x_title else x_column.title()
        y_title = y_title.title() if y_title else "Number of Passengers"

        source = data.groupby(group_by)[x_column].value_counts().reset_index()
        source["percent"] = (source["count"] / visual_df.shape[0]).round(4) * 100

        grouped_bars = (
            alt.Chart(source)
            .mark_bar(cornerRadius=10)
            .encode(
                x=alt.X(x_column, title=x_title),
                y=alt.Y(
                    "count:Q",
                    title=y_title,
                    axis=alt.Axis(
                        grid=True, gridDash=[1, 2]  # Ensure grid lines are visible
                    ),
                ),
                color=alt_color,
                column=group_by,
            )
            .encode(
                tooltip=[
                    alt.Tooltip(x_column, title=x_title),
                    alt.Tooltip("count", title=y_title),
                    alt.Tooltip("percent:Q", format=".2f", title="Percentage (%)"),
                ],
            )
            .properties(
                width=width,
                height=height,
                title=alt.Title(
                    title if title else "",
                    fontSize=18,
                    subtitle=subtitle if subtitle else "",
                    subtitleFontSize=12,
                    # dy=-10,
                ),
            )
        )

        # text_layer = (
        #     alt.Chart(source)
        #     .mark_text(
        #         align="center",
        #         baseline="bottom",  # Align text to the bottom of its bounding box
        #         dy=-5,  # Adjust vertical position (negative for above the bar)
        #         fontSize=12,
        #         fontWeight="bold",
        #         color="white",
        #     )
        #     .encode(x=x_column, y="count", text=alt.Text("count"))
        # )

        chart = grouped_bars 
        return chart

    def bar_chart(
        self,
        x_column: str,
        color: List | str = "paired",
        width: int = 200,
        height: int = 200,
        title: Optional[str] = None,
        subtitle: Optional[str] = None,
        x_title: str | None = None,
        y_title: str | None = None,
    ):

        alt_color = self.setting_colors(x_column, color=color)

        data = self.__data.copy()

        x_title = x_title.title() if x_title else x_column.title()
        y_title = y_title.title() if y_title else "Number of Passengers"

        # Return the alt chart
        bar_layer = (
            alt.Chart(data)
            .mark_bar(cornerRadius=10)
            .encode(
                x=alt.X(
                    x_column,
                    title=x_title,
                    axis=alt.Axis(grid=False, labelFontWeight="bold"),
                ),
                y=alt.Y(
                    "count()",
                    title=y_title,
                    axis=alt.Axis(grid=False, labelFontWeight="bold"),
                ),
                color=alt_color.legend(orient="right"),
                tooltip=[
                    alt.Tooltip(x_column, title=x_title),
                    alt.Tooltip("count()", title=y_title),
                ],
            )
            .properties(
                width=width,
                height=height,
                title=alt.Title(
                    title if title else "",
                    fontSize=18,
                    subtitle=subtitle if subtitle else "",
                    subtitleFontSize=12,
                    # dy=-10,
                ),
            )
        )

        text_layer = (
            alt.Chart(data)
            .mark_text(
                align="center",
                baseline="bottom",  # Align text to the bottom of its bounding box
                dy=-5,  # Adjust vertical position (negative for above the bar)
                fontSize=12,
                fontWeight="bold",
                color="white",
            )
            .encode(x=x_column, y="count()", text=alt.Text("count()"))
        )

        charts = bar_layer + text_layer

        return charts

    def donut_chart(
        self,
        x: str,
        inner_radius: int = 50,
        color: List | str = "paired",
        width: int = 200,
        height: int = 200,
    ):

        data = self.__data

        value_counts = data[x].value_counts().reset_index()
        value_counts["count"] = ((value_counts["count"] / data.shape[0]) * 100 ).round(2)

        donut_chart = (
            alt.Chart(value_counts)
            .mark_arc(innerRadius=inner_radius)
            .encode(
                theta="count",
                color=f"{x}:N",
                tooltip=[
                    alt.Tooltip(f"{x}".title()),
                    alt.Tooltip("count:Q", format=".2f", title="Percentage (%)"),
                ],
            )
            .properties(
                width=width,
                height=height,
            )
        )

        return donut_chart

    def scatter_chart(
        self,
        x: str,
        y: str,
        color_with: Optional[str] = None,
        width: int = 300,
        height: int = 300,
        title: Optional[str] = None,
        subtitle: Optional[str] = None,
        color: List[str] | str = "dark2",
        use_subplot: bool = False,
    ):
        alt_color = None

        if color_with:
            alt_color = self.setting_colors(color_with, color=color)

        tooltips = (
            [alt.Tooltip(x), alt.Tooltip(y), alt.Tooltip(color_with)]
            if color_with
            else [alt.Tooltip(x), alt.Tooltip(y)]
        )

        encode_param = (
            dict(x="%s:Q" % x, y="%s:Q" % y, color=alt_color, tooltip=tooltips)
            if color_with
            else dict(x="%s:Q" % x, y="%s:Q" % y, tooltip=tooltips)
        )

        data = self.__data

        # Scatter Plot
        points = (
            alt.Chart(data)
            .mark_point()
            .encode(**encode_param)
            .properties(
                width=width,
                height=height,
                title=alt.Title(
                    title if title else "",
                    fontSize=18,
                    subtitle=subtitle if subtitle else "",
                    subtitleFontSize=12,
                ),
            )
        )

        if use_subplot:
            return points

        points = (
            points.configure_legend(
                strokeColor="gray",
                fillColor="#EEEEEE",
                padding=10,
                cornerRadius=10,
                orient="top-right",
            )
            .configure_axis(gridDash=[5, 2, 5], gridColor="lightgrey")
            .configure_view(stroke=None)
        )

        return points.display(theme="dark")
        

    def hist_chart(
        self,
        x: str,
        width=200,
        height=200,
        n_bins=10,
        color: str | None = None,
        use_subplot: bool = False,
    ):
        data = self.__data

        # 2. Create the chart
        chart = (
            alt.Chart(data)
            .mark_bar()
            .encode(
                # Encode the 'Horsepower' column on the X-axis and apply binning
                x=alt.X("{}:Q".format(x), bin=alt.Bin(maxbins=n_bins), title=x),
                # Encode the count (frequency) on the Y-axis
                y=alt.Y("count()", title="Frequency"),
                # Add tooltips for interactivity (optional)
                tooltip=[x, "count()"],
                color=alt.Undefined if color is None else color,
            )
            .properties(title="Distribution of %s" % x, width=width, height=height)
        )

        line_data = pd.DataFrame(
            {"mean": [data[x].mean()], "median": [data[x].median()]}
        )
        mean = (
            alt.Chart(line_data)
            .mark_rule(color="red", size=2)
            .encode(x="mean", color=alt.datum("mean of %.2f" % line_data["mean"][0]))
        )

        median = (
            alt.Chart(line_data)
            .mark_rule(color="green", size=2)
            .encode(
                x="median", color=alt.datum("median of %.2f" % line_data["median"][0])
            )
        )

        hist = chart + mean + median

        if use_subplot:
            return hist
        return hist.configure_view(stroke=None).display(theme="dark")

    def box_plot(
        self, x: str, width: int = 200, height: int = 50, use_subplot: bool = False
    ):
        data = self.__data

        box_chart = (
            alt.Chart(data)
            .mark_boxplot()
            .encode(alt.X("%s:Q" % x).scale(zero=False))
            .properties(width=width)
        )

        if use_subplot:
            return box_chart
        return box_chart.configure_view(stroke=None).display(theme="dark")

    def concat(
        self,
        *args,
        use: Literal["vconcat", "hconcat"] = "vconcat",
        show_stroke: bool = False,
        title: str = "",
        subtitle: str = "",
    ):

        new_title = alt.Title(text=title, subtitle=subtitle, offset=20)

        if use == "vconcat":
            if show_stroke:
                return alt.vconcat(*args, title=new_title)
            return (
                alt.vconcat(*args, title=new_title)
                .configure_view(stroke=None)
                .display(theme="dark")
            )
        elif use == "hconcat":
            if show_stroke:
                return alt.hconcat(*args, title=new_title).display(theme="dark")
            return (
                alt.hconcat(*args, title=new_title)
                .configure_view(stroke=None)
                .display(theme="dark")
            )
        else:
            raise ValueError("Received invalid value `%s`" % use)


